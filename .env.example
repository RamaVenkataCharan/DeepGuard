# ============================================================
# DeepGuard Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# ---------- General ----------
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-64-char-string
DEBUG=true

# ---------- MySQL ----------
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=deepguard
MYSQL_PASSWORD=deepguard_secret
MYSQL_DATABASE=deepguard
DATABASE_URL=mysql+pymysql://deepguard:deepguard_secret@mysql:3306/deepguard

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ---------- JWT ----------
JWT_SECRET_KEY=change-me-to-another-random-64-char-string
JWT_ACCESS_TOKEN_EXPIRES=900
JWT_REFRESH_TOKEN_EXPIRES=2592000

# ---------- CORS ----------
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------- Weather API ----------
OPENWEATHERMAP_API_KEY=your-openweathermap-api-key
WEATHER_API_ENABLED=false

# ---------- ML ----------
ML_MODEL_PATH=../ml/artifacts
ML_MODEL_VERSION=v1.0.0
ML_SEQUENCE_LENGTH=14
ML_BATCH_SIZE=32

# ---------- Celery ----------
CELERY_TASK_ALWAYS_EAGER=false

# ---------- Logging ----------
LOG_LEVEL=INFO
LOG_FORMAT=json

# ---------- Rate Limiting ----------
RATE_LIMIT_DEFAULT=100/hour
RATE_LIMIT_AUTH=20/minute

# ---------- Report Storage ----------
REPORT_STORAGE_PATH=./reports

# ---------- MySQL Docker ----------
MYSQL_ROOT_PASSWORD=root_secret
